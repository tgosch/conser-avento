# Supabase (public — anon key ist sicher im Frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX

# Admin Login (WARNUNG: Diese Werte landen im JS-Bundle — nur für interne Tools)
# Für Production: Admin-Account in Supabase Auth anlegen statt Env-Vars
VITE_ADMIN_EMAIL=admin@yourdomain.de
VITE_ADMIN_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Anthropic Claude API (WARNUNG: Wird im Browser-Bundle sichtbar)
# Für Production: Über Backend-Proxy routen
VITE_ANTHROPIC_API_KEY=sk-ant-api03-XXXXXX

# Resend Email API (WARNUNG: Wird im Browser-Bundle sichtbar)
# TODO für Production: Über Supabase Edge Function routen — API-Key nie im Frontend exponieren
# Resend Account: https://resend.com — Domain conser-avento.de dort verifizieren
VITE_RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXX

# Supabase Service Key (nur für Owner-Portal Admin-Operationen)
# WARNUNG: Service Key bypassed RLS — NIE an Investoren/Frontend exponieren
VITE_SUPABASE_SERVICE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXX
