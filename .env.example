# ============================================================
# CONSER-AVENTO — Environment Variables Template
# Kopiere diese Datei nach .env.local und fülle die Werte ein.
# NIEMALS echte Werte committen!
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Der ANON_KEY ist öffentlich und sicher für Frontend-Bundles
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX

# ── Admin Login ───────────────────────────────────────────────
# WARNUNG: Diese Werte landen im JS-Bundle — nur für interne Owner-Tools.
# Für Production: Admin-Account in Supabase Auth anlegen und
# app_metadata.is_admin = true setzen (via SQL oder Dashboard).
# Niemals echtes Production-Passwort hier speichern.
VITE_ADMIN_EMAIL=admin@yourdomain.de
VITE_ADMIN_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# ── Anthropic Claude API ──────────────────────────────────────
# SICHERHEITSWARNUNG: Wird im Browser-Bundle sichtbar!
# Für Production: Über Supabase Edge Function oder Backend-Proxy routen.
# Supabase Edge Function: supabase/functions/claude-proxy/
VITE_ANTHROPIC_API_KEY=sk-ant-api03-XXXXXX

# ── Resend Email API ──────────────────────────────────────────
# SICHERHEITSWARNUNG: Wird im Browser-Bundle sichtbar!
# TODO für Production: Über Supabase Edge Function routen.
# Resend Account: https://resend.com — Domain dort verifizieren.
# From-Address: noreply@conser-avento.de
VITE_RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXX

# ── Perplexity API ────────────────────────────────────────────
# Nur für AI-Features im Owner-Portal verwendet.
VITE_PERPLEXITY_API_KEY=pplx-XXXXXXXXXXXXXXXXXXXXXX

# ── Google Maps API ───────────────────────────────────────────
VITE_GOOGLE_API_KEY=AIzaSyC-XXXXXXXXXXXXXXXXXXXX

# ── NICHT VERWENDEN — Nur für Backend/Edge Functions ─────────
# Der Service-Key bypassed RLS — niemals im Frontend verwenden!
# Für Backend-Operationen: in Supabase Edge Functions als
# Supabase Secret hinterlegen (supabase secrets set KEY=value)
# SUPABASE_SERVICE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXX
