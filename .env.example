# ============================================================
# CONSER-AVENTO — Environment Variables Template
# Kopiere diese Datei nach .env und fülle die echten Werte ein.
# NIEMALS echte Werte committen! Diese Datei ist nur ein Template.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────────
# Anon Key ist public by design (Supabase-Konzept, RLS schützt Daten)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX

# ── Server-Side API Keys (KEIN VITE_ Prefix!) ────────────────────
# WICHTIG: Kein VITE_ Prefix = nicht im Browser-Bundle
# Diese Keys sind nur in Vercel Edge Functions (/api/*) verfügbar.
# In Vercel Dashboard: Settings → Environment Variables setzen
# Lokal: `vercel dev` verwenden (nicht `npm run dev`)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# ── WAS HIER NICHT HINGEHÖRT ─────────────────────────────────────
# SUPABASE_SERVICE_KEY → NIEMALS im Frontend (bypasses alle RLS-Policies)
#                        → Nur in Supabase Edge Functions als Secret
# VITE_ADMIN_PASSWORD  → Nicht benötigt (Admin-Check via JWT app_metadata)
# VITE_ANTHROPIC_API_KEY → Entfernt, läuft über /api/chat Edge Function
