# Supabase (public — anon key ist sicher im Frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX

# Admin Login (WARNUNG: Diese Werte landen im JS-Bundle — nur für interne Tools)
# Für Production: Admin-Account in Supabase Auth anlegen statt Env-Vars
VITE_ADMIN_EMAIL=admin@yourdomain.de
VITE_ADMIN_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Anthropic Claude API (WARNUNG: Wird im Browser-Bundle sichtbar)
# Für Production: Über Backend-Proxy routen
VITE_ANTHROPIC_API_KEY=sk-ant-api03-XXXXXX
